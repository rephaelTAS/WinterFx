<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ossobo.winterfx.notifications.controller.NotificationControllerImpl"
      spacing="12"
      style="-fx-background-color: #e74c3c; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);"
      maxWidth="450" minWidth="350">

    <!-- Cabeçalho -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Circle radius="18" fill="white" opacity="0.9"/>
        <Label fx:id="tituloLabel"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"
               text="Erro"
               wrapText="true"/>
    </HBox>

    <!-- Descrição -->
    <Label fx:id="descricaoLabel"
           style="-fx-font-size: 14px; -fx-text-fill: white; -fx-opacity: 0.95;"
           text="Ocorreu um erro ao processar a operação."
           wrapText="true"
           maxWidth="400"/>

    <!-- Detalhes técnicos (visível para erros) -->
    <TextArea fx:id="detalhesArea"
              style="-fx-font-size: 11px; -fx-background-color: rgba(0,0,0,0.2); -fx-text-fill: white; -fx-border-radius: 6; -fx-background-radius: 6;"
              editable="false"
              wrapText="true"
              visible="false"
              managed="false"
              maxHeight="100"
              prefRowCount="4"/>

    <!-- Origem -->
    <Label fx:id="origemLabel"
           style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-style: italic;"
           visible="false"
           managed="false"/>

    <!-- Botão de fechar (para erros modais) -->
    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnFechar"
                text="Fechar"
                style="-fx-background-color: white; -fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>