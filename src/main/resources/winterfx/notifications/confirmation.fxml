<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="15"
      style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 8);"
      maxWidth="450" minWidth="380">

    <!-- Cabeçalho: Ícone + Título -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Circle radius="20" fill="#f39c12" opacity="0.9"/>
        <Label fx:id="tituloLabel"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
               text="Confirmação"
               wrapText="true"/>
    </HBox>

    <!-- Descrição -->
    <Label fx:id="descricaoLabel"
           style="-fx-font-size: 15px; -fx-text-fill: #555555; -fx-line-spacing: 4px;"
           text="Tem certeza que deseja continuar?"
           wrapText="true"
           maxWidth="400"/>

    <!-- Detalhes técnicos (opcional) -->
    <TextArea fx:id="detalhesArea"
              style="-fx-font-size: 11px; -fx-background-color: #f5f5f5; -fx-text-fill: #777; -fx-border-radius: 6; -fx-background-radius: 6; -fx-border-color: #ddd;"
              editable="false"
              wrapText="true"
              visible="false"
              managed="false"
              maxHeight="80"
              prefRowCount="3"/>

    <!-- Origem (oculto) -->
    <Label fx:id="origemLabel"
           style="-fx-font-size: 10px; -fx-text-fill: #999; -fx-font-style: italic;"
           visible="false"
           managed="false"/>

    <!-- Botões de ação -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar"
                text="Cancelar"
                style="-fx-background-color: #ecf0f1; -fx-text-fill: #555; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
        <Button fx:id="btnConfirmar"
                text="Confirmar"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
    </HBox>

</VBox>