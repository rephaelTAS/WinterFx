<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import java.net.URL?>
<VBox fx:id="containerPrincipal" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ossobo.nexusfx.AlertSystem.fx.AlertaController"
      styleClass="alerta-naomodal"
      prefWidth="350" prefHeight="140"
      spacing="8">

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <!-- Cabeçalho compacto -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label fx:id="lblTitulo" styleClass="alerta-titulo-naomodal"
               text="Título" wrapText="true"
               HBox.hgrow="ALWAYS"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTempo" styleClass="alerta-tempo-pequeno"
               text="3s"/>
    </HBox>

    <!-- Descrição compacta - MUDADO: TextArea → Label -->
    <Label fx:id="txtDescricao" styleClass="alerta-descricao-naomodal"
           wrapText="true" maxHeight="50"
           VBox.vgrow="ALWAYS"/>

    <!-- Rodapé com origem -->
    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="lblOrigem" styleClass="alerta-origem-naomodal"
               text="Sistema"/>
    </HBox>

</VBox>