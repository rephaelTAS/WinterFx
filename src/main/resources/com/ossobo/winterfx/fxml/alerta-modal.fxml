<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="containerPrincipal" prefHeight="200" prefWidth="400" spacing="10"
      styleClass="alerta-modal"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ossobo.nexusfx.AlertSystem.fx.AlertaController">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <!-- Cabeçalho -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label fx:id="lblTitulo" styleClass="alerta-titulo-modal"
               text="Título do Alerta" wrapText="true"
               HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Descrição -->
    <Label fx:id="lblDescricao" styleClass="alerta-descricao-modal"
           text="Label" wrapText="true"
           VBox.vgrow="ALWAYS"/>

    <!-- Informações -->
    <HBox spacing="20">
        <Label fx:id="lblOrigem" styleClass="alerta-origem-modal"
               text="Origem: Sistema" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Botões -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="btnDetalhes" styleClass="botao-detalhes"
                text="Detalhes" />
        <Button fx:id="btnOk" defaultButton="true"
                styleClass="botao-primario" text="OK" />
    </HBox>

</VBox>