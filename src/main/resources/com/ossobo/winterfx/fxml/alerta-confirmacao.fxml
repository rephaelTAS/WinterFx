<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox fx:id="container" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ossobo.nexusfx.AlertSystem.fx.AlertaConfirmacaoController"
      alignment="CENTER" spacing="12"
      minWidth="380" maxWidth="420"
      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 10);">

    <padding>
        <Insets top="18" right="20" bottom="14" left="20"/>
    </padding>

    <!-- Ícone -->
    <Label fx:id="lblIcon" text="❓" style="-fx-font-size: 32px;"/>

    <!-- Mensagem principal (sempre visível) -->
    <Label fx:id="lblMessage" wrapText="true" textAlignment="CENTER" alignment="CENTER"
           style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"
           maxWidth="360" minHeight="20"/>

    <!-- Detalhes (opcional, scroll se muito longo) -->
    <Label fx:id="lblDetails" wrapText="true" textAlignment="CENTER" alignment="CENTER"
           style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-style: italic;"
           maxWidth="360" maxHeight="80"
           visible="false" managed="false"/>

    <!-- Espaçador -->
    <Region prefHeight="4"/>

    <!-- Botões sempre visíveis no fundo -->
    <HBox fx:id="buttonContainer" alignment="CENTER" spacing="12">
        <Button fx:id="btnCancelar" text="✕ Cancelar"
                style="-fx-background-color: #e0e0e0; -fx-text-fill: #333; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button fx:id="btnConfirmar" text="✓ Confirmar"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>